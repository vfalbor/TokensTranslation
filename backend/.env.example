# ─────────────────────────────────────────────────────────
# TokenTranslation — Environment Configuration
# Copy this file to .env and edit before first run.
# ─────────────────────────────────────────────────────────

# ── Security (REQUIRED) ───────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# ── Translation Backend ───────────────────────────────────
# "google"  → uses Google Translate (unofficial free API by default)
# "local"   → uses argostranslate (runs on VPS, no external calls)
TRANSLATION_BACKEND=google

# ── Google Translate API Key (optional) ──────────────────
# Leave empty to use the free unofficial endpoint (no key required).
# Set to your Google Cloud API key to use the official paid API.
GOOGLE_TRANSLATE_API_KEY=

# ── Token Optimization Target Language ───────────────────
# Language code that prompts are translated INTO before reaching the LLM.
# "en" is recommended (best balance of efficiency + LLM quality).
# "zh" is slightly more token-efficient but may reduce LLM reasoning quality.
EFFICIENT_LANGUAGE=en

# ── Database ───────────────────────────────────────────────
# SQLite (default, no setup needed):
DATABASE_URL=sqlite+aiosqlite:///./tokentranslation.db

# PostgreSQL (recommended for production):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/tokentranslation

# ── Application ────────────────────────────────────────────
DEBUG=false
APP_NAME=TokenTranslation
APP_VERSION=1.0.0

# ── CORS (comma-separated origins or * for all) ──────────
# Example: CORS_ORIGINS=["https://yourdomain.com","http://localhost:3000"]
CORS_ORIGINS=["*"]

# ── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT=100/minute
